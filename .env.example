# Documentation only. Do not source this file in production and do not commit secrets.
IVPN_LISTEN=127.0.0.1:8443
IVPN_ORIGIN=https://ivpn.internal
IVPN_RPID=ivpn.internal
IVPN_DATABASE=/var/lib/ivpn/ivpn.db
IVPN_MASTER_KEY_FILE=/run/credentials/ivpn-controller/master-key
IVPN_BOOTSTRAP_TOKEN_FILE=/run/credentials/ivpn-controller/bootstrap-token
IVPN_TLS_CERT=/etc/ivpn/tls/controller.crt
IVPN_TLS_KEY=/etc/ivpn/tls/controller.key
IVPN_DRY_RUN=true
IVPN_DEV_MODE=false
IVPN_TIMEZONE=Europe/Paris
IVPN_X_ESTIMATED_CHARGE=<operator-supplied-account-estimate>
